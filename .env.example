# ── Backend (Express server — run locally or on Railway/Render) ──────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=        # same as OPENROUTER_API_KEY if using OpenRouter
APP_URL=http://localhost:3000
PORT=3000

# ── Frontend (Vite — set this on Vercel dashboard) ────────────────────────────
# Leave empty for local dev (frontend and backend run on same port)
# Set to your Railway/Render backend URL for production, e.g.:
#   VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=
BACKEND_API_URL=      # Used by Vercel API routes to proxy upload/extract requests
